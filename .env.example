# DeepSeek API (primary — ~300₽/month)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq API (free fallback — 14,400 requests/day)
# Get key at https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional
LLM_MODEL=deepseek-chat
GROQ_MODEL=llama-3.1-8b-instant
CHROMA_DB_PATH=./chroma_db
SYSTEM_PROMPT=Ты helpful ассистент. Отвечай на основе загруженных документов. Если не знаешь ответа — скажи честно.
